                    }
                  ]
                },
                {
                  "FullText": "Call `remove` on the component to mark it as removed. It's up to the implementation",
                  "Elements": [
                    {
                      "RawText": "Call `remove` on the component to mark it as removed. It's up to the implementation",
                      "ElementType": 1
                    }
                  ]
                },
                {
                  "FullText": "to define what is does on the act of removal. Basic implementation of `Component`",
                  "Elements": [
                    {
                      "RawText": "to define what is does on the act of removal. Basic implementation of `Component`",
                      "ElementType": 1
                    }
                  ]
                },
                {
                  "FullText": "will switch it to inactive state and it cannot be activated again.",
                  "Elements": [
                    {
                      "RawText": "will switch it to inactive state and it cannot be activated again.",
                      "ElementType": 1
                    }
                  ]
                }
              ],
              "TagType": 7,
              "TagName": "",
              "RawText": "*\n     * Call `remove` on the component to mark it as removed. It's up to the implementation\n     * to define what is does on the act of removal. Basic implementation of `Component`\n     * will switch it to inactive state and it cannot be activated again.\n",
              "ElementType": 2
            }
          }
