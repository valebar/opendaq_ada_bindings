      "Documentation": {
        "Brief": {
          "TagIndex": 0,
          "Lines": [
            {
              "FullText": "Interface representing a Synchronization Component in a Test & Measurement system.",
              "Elements": [
                {
                  "RawText": "Interface representing a Synchronization Component in a Test & Measurement system.",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "A SynchronizationComponent ensures synchronization among measurement devices in the system.",
              "Elements": [
                {
                  "RawText": "A SynchronizationComponent ensures synchronization among measurement devices in the system.",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "It can act as a sync source and/or as a sync output, with each component having one sync input",
              "Elements": [
                {
                  "RawText": "It can act as a sync source and/or as a sync output, with each component having one sync input",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "and 0 to n sync outputs.",
              "Elements": [
                {
                  "RawText": "and 0 to n sync outputs.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 1,
          "TagName": "brief",
          "RawText": "* @brief Interface representing a Synchronization Component in a Test & Measurement system.\n * A SynchronizationComponent ensures synchronization among measurement devices in the system.\n * It can act as a sync source and/or as a sync output, with each component having one sync input\n * and 0 to n sync outputs.\n",
          "ElementType": 2
        },
        "Tags": [
          {
            "Lines": [
              {
                "FullText": "Every SynchronizationComponent has at least one interface. Only one interface can be set",
                "Elements": [
                  {
                    "RawText": "Every SynchronizationComponent has at least one interface. Only one interface can be set",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "as an input, while others can be used as sync outputs to synchronize other devices.",
                "Elements": [
                  {
                    "RawText": "as an input, while others can be used as sync outputs to synchronize other devices.",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "The configuration of these interfaces and the reading of their status is defined in Part 4.",
                "Elements": [
                  {
                    "RawText": "The configuration of these interfaces and the reading of their status is defined in Part 4.",
                    "ElementType": 1
                  }
                ]
              }
            ],
            "TagType": 0,
            "TagName": "note",
            "RawText": "@note Every SynchronizationComponent has at least one interface. Only one interface can be set\n * as an input, while others can be used as sync outputs to synchronize other devices.\n * The configuration of these interfaces and the reading of their status is defined in Part 4.",
            "ElementType": 2
          },
          {
            "Lines": [
              {
                "FullText": "Depending on the setup, some interfaces may be switched off, and some interfaces may",
                "Elements": [
                  {
                    "RawText": "Depending on the setup, some interfaces may be switched off, and some interfaces may",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "act as sync sources or outputs.",
                "Elements": [
                  {
                    "RawText": "act as sync sources or outputs.",
                    "ElementType": 1
                  }
                ]
              }
            ],
            "TagType": 0,
            "TagName": "note",
            "RawText": "@note Depending on the setup, some interfaces may be switched off, and some interfaces may\n * act as sync sources or outputs.",
            "ElementType": 2
          },
          {
            "Lines": [
              {
                "FullText": "A CLK interface can be used to let a device run in Fre-Run mode, where the device",
                "Elements": [
                  {
                    "RawText": "A CLK interface can be used to let a device run in Fre-Run mode, where the device",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "syncs internally to an internal quartz.",
                "Elements": [
                  {
                    "RawText": "syncs internally to an internal quartz.",
                    "ElementType": 1
                  }
                ]
              }
            ],
            "TagType": 0,
            "TagName": "note",
            "RawText": "@note A CLK interface can be used to let a device run in Fre-Run mode, where the device\n * syncs internally to an internal quartz.",
