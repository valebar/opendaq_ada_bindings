      "Documentation": {
        "Brief": {
          "TagIndex": 0,
          "Lines": [
            {
              "FullText": "An ownable object can have IPropertyObject as the owner.",
              "Elements": [
                {
                  "RawText": "An ownable object can have IPropertyObject as the owner.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 1,
          "TagName": "brief",
          "RawText": "* @brief An ownable object can have IPropertyObject as the owner.\n",
          "ElementType": 2
        },
        "Tags": [
          {
            "TagIndex": 2,
            "Lines": [
              {
                "FullText": "",
                "Elements": [
                  {
                    "RawText": "",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "For example, a property object that is a child of another property object will look up property values",
                "Elements": [
                  {
                    "RawText": "For example, a property object that is a child of another property object will look up property values",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "in their owner's dictionary if the property is not set locally.",
                "Elements": [
                  {
                    "RawText": "in their owner's dictionary if the property is not set locally.",
                    "ElementType": 1
                  }
                ]
              }
            ],
            "TagType": 7,
            "TagName": "",
            "RawText": "*\n * For example, a property object that is a child of another property object will look up property values \n * in their owner's dictionary if the property is not set locally.\n",
            "ElementType": 2
          }
        ],
        "Description": {
          "TagIndex": 1,
          "Lines": [
            {
              "FullText": "",
              "Elements": [
                {
                  "RawText": "",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "An object can declare itself ownable. When a parent object that supports a concept of ownership",
              "Elements": [
                {
                  "RawText": "An object can declare itself ownable. When a parent object that supports a concept of ownership",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "calls the` setOwner` method, it becomes the owner of the object. It's up to the object's implementation",
              "Elements": [
                {
                  "RawText": "calls the` setOwner` method, it becomes the owner of the object. It's up to the object's implementation",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "to decide what actions should it forward to the owner.",
              "Elements": [
                {
                  "RawText": "to decide what actions should it forward to the owner.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 7,
          "TagName": "",
          "RawText": "*\n * An object can declare itself ownable. When a parent object that supports a concept of ownership\n * calls the` setOwner` method, it becomes the owner of the object. It's up to the object's implementation\n * to decide what actions should it forward to the owner.\n",
          "ElementType": 2
        }
      }
