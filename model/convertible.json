          },
          {
            "Lines": [],
            "TagType": 0,
            "TagName": "code",
            "RawText": "@code\n * IIntObject* intObj = ...;\n * IConvertible* conv;\n * auto errCode = intObj.queryInterface(IConvertible::Id, reinterpret_cast<void**>(&conv));\n * if (OPENDAQ_FAILED(errCode))\n *   return;\n *\n * Float val;\n * errCode = conv->toFloat(&val);\n * if (OPENDAQ_FAILED(errCode))\n *   return;\n *\n * // print val\n * @endcode",
            "ElementType": 2
          }
        ],
