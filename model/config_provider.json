      "Documentation": {
        "Brief": {
          "TagIndex": 0,
          "Lines": [
            {
              "FullText": "Config provider is an interface that was made for populating an options dictionary of an instance builder from external sources",
              "Elements": [
                {
                  "RawText": "Config provider is an interface that was made for populating an options dictionary of an instance builder from external sources",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "like a config file, environment variables, or command line arguments.",
              "Elements": [
                {
                  "RawText": "like a config file, environment variables, or command line arguments.",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "The process of population of the dictionary have to be alligned with rules:",
              "Elements": [
                {
                  "RawText": "The process of population of the dictionary have to be alligned with rules:",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "- all keys are set in lowercase. Values are set without case changes.",
              "Elements": [
                {
                  "RawText": "- all keys are set in lowercase. Values are set without case changes.",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "- if a provider is trying to override an existing value, it has to have the same type. For example provider can not replace integer value with string or object with list",
              "Elements": [
                {
                  "RawText": "- if a provider is trying to override an existing value, it has to have the same type. For example provider can not replace integer value with string or object with list",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "- if a provider is overriding a list, it replaces old list items with a new one.",
              "Elements": [
                {
                  "RawText": "- if a provider is overriding a list, it replaces old list items with a new one.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 1,
          "TagName": "brief",
          "RawText": "* @brief Config provider is an interface that was made for populating an options dictionary of an instance builder from external sources\n * like a config file, environment variables, or command line arguments.\n * The process of population of the dictionary have to be alligned with rules:\n * - all keys are set in lowercase. Values are set without case changes.\n * - if a provider is trying to override an existing value, it has to have the same type. For example provider can not replace integer value with string or object with list\n * - if a provider is overriding a list, it replaces old list items with a new one. \n",
          "ElementType": 2
        },
        "Tags": [],
        "Description": null
      }
    }
