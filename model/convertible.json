              ]
            },
            {
              "FullText": "An object which implements `IIntObject` will typically also implement IConvertible,",
              "Elements": [
                {
                  "RawText": "An object which implements `IIntObject` will typically also implement IConvertible,",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "which allows conversion to other types.",
              "Elements": [
                {
                  "RawText": "which allows conversion to other types.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 7,
          "TagName": "",
          "RawText": "*\n * An object which implements `IIntObject` will typically also implement IConvertible,\n * which allows conversion to other types.\n",
