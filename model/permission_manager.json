        "Brief": {
          "TagIndex": 0,
          "Lines": [
            {
              "FullText": "A class which is responsible for managing permissions on an object level. Given a user's group,",
              "Elements": [
                {
                  "RawText": "A class which is responsible for managing permissions on an object level. Given a user's group,",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "it is possible to restrict or allow read, write and execute permissions for each object. It is also",
              "Elements": [
                {
                  "RawText": "it is possible to restrict or allow read, write and execute permissions for each object. It is also",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "possible to specify if permissions are inherited from parent object",
              "Elements": [
                {
                  "RawText": "possible to specify if permissions are inherited from parent object",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 1,
          "TagName": "brief",
          "RawText": "* @brief A class which is responsible for managing permissions on an object level. Given a user's group,\n * it is possible to restrict or allow read, write and execute permissions for each object. It is also\n * possible to specify if permissions are inherited from parent object\n",
          "ElementType": 2
        },
