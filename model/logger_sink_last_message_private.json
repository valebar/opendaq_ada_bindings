                "Lines": [
                  {
                    "FullText": "The timeout in milliseconds until which wait for a new log message. If timeout set as 0 ms waiting will be skipped.",
                    "Elements": [
                      {
                        "RawText": "The timeout in milliseconds until which wait for a new log message. If timeout set as 0 ms waiting will be skipped.",
                        "ElementType": 1
                      }
                    ]
                  }
                ],
                "TagType": 3,
                "TagName": "param",
                "RawText": "@param timeoutMs The timeout in milliseconds until which wait for a new log message. If timeout set as 0 ms waiting will be skipped.",
                "ElementType": 2
              },
              {
                "ParamName": "success",
                "IsOut": true,
                "Lines": [
                  {
                    "FullText": "The success will return true if there was a new unread log message before waiting",
                    "Elements": [
                      {
                        "RawText": "The success will return true if there was a new unread log message before waiting",
                        "ElementType": 1
                      }
                    ]
                  },
                  {
                    "FullText": "or sink got a new logger message before timeout. False if timeout was reached.",
                    "Elements": [
                      {
                        "RawText": "or sink got a new logger message before timeout. False if timeout was reached.",
                        "ElementType": 1
                      }
                    ]
                  }
                ],
                "TagType": 3,
                "TagName": "param",
                "RawText": "@param[out] success The success will return true if there was a new unread log message before waiting\n     * or sink got a new logger message before timeout. False if timeout was reached.",
