      "Documentation": {
        "Brief": {
          "TagIndex": 0,
          "Lines": [
            {
              "FullText": "Provides an interface to manipulate the configuration of a device's (server's) network interface.",
              "Elements": [
                {
                  "RawText": "Provides an interface to manipulate the configuration of a device's (server's) network interface.",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "Offers methods to update the IP configuration and retrieve the currently active one, if the corresponding feature",
              "Elements": [
                {
                  "RawText": "Offers methods to update the IP configuration and retrieve the currently active one, if the corresponding feature",
                  "ElementType": 1
                }
              ]
            },
            {
              "FullText": "supported by the device. Additionally, includes a helper method to create a prebuilt property object with valid default configuration.",
              "Elements": [
                {
                  "RawText": "supported by the device. Additionally, includes a helper method to create a prebuilt property object with valid default configuration.",
                  "ElementType": 1
                }
              ]
            }
          ],
          "TagType": 1,
          "TagName": "brief",
          "RawText": "* @brief Provides an interface to manipulate the configuration of a device's (server's) network interface.\n * Offers methods to update the IP configuration and retrieve the currently active one, if the corresponding feature\n * supported by the device. Additionally, includes a helper method to create a prebuilt property object with valid default configuration.\n",
          "ElementType": 2
        },
        "Tags": [
          {
            "TagIndex": 2,
            "Lines": [
              {
                "FullText": "",
                "Elements": [
                  {
                    "RawText": "",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "- **\"dhcp4\"**: A boolean property indicating whether DHCP is enabled for IPv4. Defaults to `True` (DHCP enabled).",
                "Elements": [
                  {
                    "RawText": "- **\"dhcp4\"**: A boolean property indicating whether DHCP is enabled for IPv4. Defaults to `True` (DHCP enabled).",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "If set to `False` (DHCP disabled), non-empty static configuration properties are required.",
                "Elements": [
                  {
                    "RawText": "If set to `False` (DHCP disabled), non-empty static configuration properties are required.",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "- **\"address4\"**: A string property specifying the statically assigned IPv4 address in the format `address/netmask` (e.g. 192.168.1.2/24).",
                "Elements": [
                  {
                    "RawText": "- **\"address4\"**: A string property specifying the statically assigned IPv4 address in the format `address/netmask` (e.g. 192.168.1.2/24).",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "This property is ignored when DHCP is enabled for IPv4. However, if DHCP is disabled, the list must include at least one address. Defaults to an empty string.",
                "Elements": [
                  {
                    "RawText": "This property is ignored when DHCP is enabled for IPv4. However, if DHCP is disabled, the list must include at least one address. Defaults to an empty string.",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "- **\"gateway4\"**: A string property specifying the IPv4 gateway address. This is required if DHCP is disabled and ignored otherwise. Defaults to an empty string.",
                "Elements": [
                  {
                    "RawText": "- **\"gateway4\"**: A string property specifying the IPv4 gateway address. This is required if DHCP is disabled and ignored otherwise. Defaults to an empty string.",
                    "ElementType": 1
                  }
                ]
              },
              {
                "FullText": "- **\"dhcp6\"**, **\"address6\"**, **\"gateway6\"**: These properties follow the same format and rules as their IPv4 counterparts but apply to IPv6 configuration.",
                "Elements": [
                  {
                    "RawText": "- **\"dhcp6\"**, **\"address6\"**, **\"gateway6\"**: These properties follow the same format and rules as their IPv4 counterparts but apply to IPv6 configuration.",
                    "ElementType": 1
                  }
                ]
              }
            ],
            "TagType": 7,
            "TagName": "",
            "RawText": "*\n * - **\"dhcp4\"**: A boolean property indicating whether DHCP is enabled for IPv4. Defaults to `True` (DHCP enabled).\n *   If set to `False` (DHCP disabled), non-empty static configuration properties are required.\n * - **\"address4\"**: A string property specifying the statically assigned IPv4 address in the format `address/netmask` (e.g. 192.168.1.2/24).\n *   This property is ignored when DHCP is enabled for IPv4. However, if DHCP is disabled, the list must include at least one address. Defaults to an empty string.\n * - **\"gateway4\"**: A string property specifying the IPv4 gateway address. This is required if DHCP is disabled and ignored otherwise. Defaults to an empty string.\n * - **\"dhcp6\"**, **\"address6\"**, **\"gateway6\"**: These properties follow the same format and rules as their IPv4 counterparts but apply to IPv6 configuration.\n",
            "ElementType": 2
          }
        ],
